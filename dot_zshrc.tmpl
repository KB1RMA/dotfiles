# --- Path ---
export PATH=$HOME/bin:/usr/local/bin:/usr/local/sbin:/Users/{{ .chezmoi.username }}/.local/bin:$PATH

{{ if hasPrefix "LIBP" .chezmoi.hostname }}
export AWS_CA_BUNDLE=/Users/Shared/.certificates/zscaler.pem
export GIT_SSL_CAINFO=/Users/Shared/.certificates/zscaler.crt
export CURL_CA_BUNDLE=/Users/Shared/.certificates/zscaler.pem
export NODE_EXTRA_CA_CERTS=/Users/Shared/.certificates/zscaler.pem
{{ end }}

export HOMEBREW_NO_ANALYTICS=1
export LANG=en_US.UTF-8

# --- Completion ---
autoload -Uz compinit
compinit

zstyle ':completion:*' matcher-list 'm:{a-zA-Z-_}={A-Za-z_-}'  # case/hyphen insensitive
zstyle ':completion:*' menu select                                # highlight selection
zstyle ':completion:*' list-colors ''                             # colorize completions

# --- History ---
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt APPEND_HISTORY
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS

# --- Directory options ---
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS

# --- Correction ---
setopt CORRECT

# --- Vi mode ---
bindkey -v
export KEYTIMEOUT=1

# --- Colored man pages ---
export LESS_TERMCAP_mb=$'\e[1;31m'
export LESS_TERMCAP_md=$'\e[1;36m'
export LESS_TERMCAP_me=$'\e[0m'
export LESS_TERMCAP_se=$'\e[0m'
export LESS_TERMCAP_so=$'\e[1;44;33m'
export LESS_TERMCAP_ue=$'\e[0m'
export LESS_TERMCAP_us=$'\e[1;32m'

# --- pyenv ---
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init --path)"
eval "$(pyenv init -)"

# --- nvm (lazy loaded) ---
export NVM_DIR="$HOME/.nvm"

# Add nvm's default node to PATH eagerly so tools like starship can find it
# Set your default with: nvm alias default <version>
if [ -d "$NVM_DIR/versions/node" ] && [ -f "$NVM_DIR/alias/default" ]; then
  _nvm_default=$(cat "$NVM_DIR/alias/default" | tr -d 'v ')
  _nvm_default_dir=$(ls -d "$NVM_DIR/versions/node/v${_nvm_default}"* 2>/dev/null | sort -V | tail -1)
  [ -n "$_nvm_default_dir" ] && export PATH="$_nvm_default_dir/bin:$PATH"
  unset _nvm_default _nvm_default_dir
fi

nvm() {
  unfunction nvm node npm npx 2>/dev/null
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
  nvm "$@"
}
node() { nvm --version >/dev/null 2>&1; unfunction node 2>/dev/null; command node "$@"; }
npm()  { nvm --version >/dev/null 2>&1; unfunction npm  2>/dev/null; command npm  "$@"; }
npx()  { nvm --version >/dev/null 2>&1; unfunction npx  2>/dev/null; command npx  "$@"; }
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# Auto-use .nvmrc when entering a directory
autoload -U add-zsh-hook
load-nvmrc() {
  local nvmrc_path="$(nvm_find_nvmrc 2>/dev/null)"
  if [ -n "$nvmrc_path" ]; then
    local nvmrc_node_version=$(nvm version "$(cat "${nvmrc_path}")")
    if [ "$nvmrc_node_version" = "N/A" ]; then
      nvm install
    elif [ "$nvmrc_node_version" != "$(nvm version)" ]; then
      nvm use
    fi
  fi
}
add-zsh-hook chpwd load-nvmrc

# --- fzf ---
source <(fzf --zsh)

# --- Plugins (Homebrew) ---
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# --- Editor ---
alias vim='nvim'
alias vi='nvim'
export EDITOR='nvim'
export VISUAL='nvim'
export GIT_EDITOR='nvim'

# --- bat ---
alias cat='bat'
export BAT_THEME='TwoDark'

# --- General aliases ---
alias l='ls -lah $1'
alias dc='docker-compose $1'
alias dc-dev='eval $(<~/.docker/dev-ddc/env.sh)'
alias dc-np='eval $(<~/.docker/np-ddc/env.sh)'

# --- Git aliases (replaces oh-my-zsh git plugin) ---
alias g='git'
alias ga='git add'
alias gaa='git add --all'
alias gb='git branch'
alias gba='git branch --all'
alias gc='git commit --verbose'
alias gc!='git commit --verbose --amend'
alias gca='git commit --verbose --all'
alias gcb='git checkout -b'
alias gco='git checkout'
alias gd='git diff'
alias gdca='git diff --cached'
alias gf='git fetch'
alias gl='git pull'
alias glog='git log --oneline --decorate --graph'
alias gm='git merge'
alias gp='git push'
alias gpf!='git push --force-with-lease'
alias grb='git rebase'
alias grbi='git rebase --interactive'
alias gst='git status'
alias gsw='git switch'
alias gswc='git switch --create'

# --- Custom functions ---

# cd into ~/repos/<name> with tab completion for subdirectories
cdrepo() { cd ~/repos/$1 }
_cdrepo() { _files -W ~/repos -/ }
compdef _cdrepo cdrepo

# --- Extra paths ---
export PATH="/Users/{{ .chezmoi.username }}/go/bin/air:$PATH"

### MANAGED BY RANCHER DESKTOP START (DO NOT EDIT)
export PATH="/Users/{{ .chezmoi.username }}/.rd/bin:$PATH"
### MANAGED BY RANCHER DESKTOP END (DO NOT EDIT)

# --- Starship prompt (must be last) ---
eval "$(starship init zsh)"
